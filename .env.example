ENVIRONMENT=production
REQUIRE_WSS=true
WEBSOCKET_ALLOWED_ORIGINS=https://www.youtube.com,https://youtube.com,https://m.youtube.com,chrome-extension://*

AUTH_TOKENS=
TRANSLATION_PROVIDER=openai
TTS_PROVIDER=openai
MAX_CHUNK_CONCURRENCY=1
MAX_TRANSCRIPT_ITEMS=2000
MAX_TEXT_CHARS_PER_CHUNK=4000
PROVIDER_TIMEOUT_SECONDS=45
PROVIDER_MAX_RETRIES=8
PROVIDER_RETRY_BASE_DELAY_SECONDS=1.0
PROVIDER_RETRY_MAX_DELAY_SECONDS=90.0
RATE_LIMIT_CONNECTIONS_PER_MINUTE=30
RATE_LIMIT_CHUNKS_PER_MINUTE=3000

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_MALE_VOICE=onyx
OPENAI_TTS_FEMALE_VOICE=coral
OPENAI_TTS_RESPONSE_FORMAT=mp3
OPENAI_TTS_INSTRUCTIONS=Sprich klares, natuerliches Hochdeutsch mit ruhiger Synchronisationsgeschwindigkeit. Der Text ist fuer gesprochene Ausgabe vorbereitet; lies Zahlen, Jahre, Uhrzeiten, Prozentwerte, Geldbetraege und Einheiten natuerlich im Kontext vor. Englische Akronyme, Agenturnamen und Tech-Begriffe wie CIA, FBI, NSA, AI, API, GPU, URL, VPN, USB, HTML und HTTPS werden auf Englisch ausgesprochen oder buchstabiert. Eigennamen und Produktnamen nicht eindeutschen.

DEEPL_API_KEY=
DEEPL_API_BASE=https://api.deepl.com

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Live Video Translation
OPENROUTER_MAX_TOKENS=220
OPENROUTER_TEMPERATURE=0.2

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Microsoft Edge neural voices via edge-tts. Use TTS_PROVIDER=edge_tts.
EDGE_TTS_MALE_VOICE=de-DE-ConradNeural
EDGE_TTS_FEMALE_VOICE=de-DE-KatjaNeural
EDGE_TTS_DEFAULT_VOICE=de-DE-ConradNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH_NORMAL=+0Hz
EDGE_TTS_PITCH_LOW=-25Hz
EDGE_TTS_PITCH_HIGH=+25Hz

# Gemini TTS. Use TTS_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-tts
GEMINI_TTS_MALE_VOICE=Puck
GEMINI_TTS_FEMALE_VOICE=Kore
GEMINI_TTS_SAMPLE_RATE=24000
GEMINI_TTS_INSTRUCTIONS=Sprich klares, natuerliches Hochdeutsch. Der Text ist fuer gesprochene Ausgabe vorbereitet; lies Zahlen, Jahre, Uhrzeiten, Prozentwerte, Geldbetraege und Einheiten natuerlich im Kontext vor. Englische Akronyme, Agenturnamen und Tech-Begriffe wie CIA, FBI, NSA, AI, API, GPU, URL, VPN, USB, HTML und HTTPS werden auf Englisch ausgesprochen oder buchstabiert. Eigennamen und Produktnamen nicht eindeutschen.

# Local open-source Piper TTS. Use TTS_PROVIDER=piper.
PIPER_EXE_PATH=
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
PIPER_MALE_MODEL_PATH=
PIPER_MALE_CONFIG_PATH=
PIPER_FEMALE_MODEL_PATH=
PIPER_FEMALE_CONFIG_PATH=
PIPER_SENTENCE_SILENCE_SECONDS=0.05
PIPER_LENGTH_SCALE=1.0
PIPER_MIN_LENGTH_SCALE=0.72
PIPER_MAX_LENGTH_SCALE=1.15
PIPER_ESTIMATED_CHARS_PER_SECOND=18.0
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W=0.8

# Local Windows-only development TTS. Use TTS_PROVIDER=windows_sapi.
WINDOWS_SAPI_VOICE=
WINDOWS_SAPI_GENDER=male
WINDOWS_SAPI_RATE=0

TTS_PRONUNCIATION_ENABLED=true
TTS_PRONUNCIATION_MODE=auto
TTS_ENGLISH_INITIALISMS=ADHD,AGI,AI,API,AR,BIOS,CIA,CPU,CSS,CTO,FBI,FPS,GPU,HTML,HTTP,HTTPS,IT,JSON,LLM,ML,NATO,NSA,OS,PDF,RAM,REST,SQL,UI,UK,URL,US,USA,USB,UX,VPN,VR,XML
