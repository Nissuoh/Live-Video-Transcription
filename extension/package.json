{
  "name": "live-video-translation-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "local:unpacked": "npm run build && node scripts/build-local-unpacked.mjs",
    "package": "npm run build && node scripts/package-extension.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "0.1.18",
    "typescript": "5.9.3",
    "yazl": "^3.3.1"
  }
}
